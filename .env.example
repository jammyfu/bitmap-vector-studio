# Bitmap Vector Studio 环境配置模板
# 复制为 .env 并修改为你自己的配置

# =============================================================================
# API 服务 (FastAPI + Uvicorn)
# =============================================================================
BVS_API_HOST=0.0.0.0
BVS_API_PORT=8000

# Uvicorn 工作进程数 (生产环境建议 CPU 核心数 * 2 + 1)
BVS_API_WORKERS=1

# 开发模式自动重载 (仅开发环境)
BVS_API_RELOAD=false

# =============================================================================
# Streamlit GUI
# =============================================================================
BVS_STREAMLIT_PORT=8501
BVS_STREAMLIT_ADDRESS=0.0.0.0

# =============================================================================
# 数据目录
# =============================================================================
BVS_DATA_DIR=~/.bitmap_vector_studio

# 输入/输出目录 (Docker 挂载用)
BVS_INPUTS_DIR=./inputs
BVS_OUTPUTS_DIR=./outputs

# =============================================================================
# 渲染农场 (分布式处理)
# =============================================================================
BVS_FARM_COORDINATOR_URL=http://localhost:8000
BVS_WORKER_ID=worker-1
BVS_WORKER_PORT=9001
BVS_WORKER_REPLICAS=2

# =============================================================================
# 云端同步
# =============================================================================
BVS_CLOUD_SYNC_ENABLED=false
BVS_CLOUD_API_KEY=
BVS_CLOUD_ENDPOINT=

# =============================================================================
# 性能与硬件加速
# =============================================================================
BVS_GPU_ENABLED=false
BVS_MEMORY_LIMIT_MB=
BVS_MAX_WORKERS=4

# =============================================================================
# 日志
# =============================================================================
BVS_LOG_LEVEL=INFO
BVS_LOG_FORMAT=json
